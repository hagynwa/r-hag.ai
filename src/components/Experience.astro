<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.expand-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const expandable = this.nextElementSibling;
        const isOpen = expandable.classList.toggle('open');
        this.classList.toggle('open');
        const lang = document.documentElement.lang || 'en';
        this.querySelector('span:first-child').textContent = isOpen
          ? (this.getAttribute(`data-${lang}-open`) || 'Show less')
          : (this.getAttribute(`data-${lang}-closed`) || 'See more');
      });
    });
  });
</script>

