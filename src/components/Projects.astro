---

<section id="projects">
  <div class="section-inner">
    <div class="section-label reveal" data-en="Portfolio" data-he="פורטפוליו">Portfolio</div>
    <h2 class="section-title reveal" data-en="Things I've Built" data-he="דברים שבניתי">Things I've Built</h2>
    <p class="section-subtitle reveal" data-en="Every project started with a real problem &mdash; for me, my family, or my community." data-he="כל פרויקט התחיל מבעיה אמיתית &mdash; שלי, של המשפחה, או של הקהילה.">Every project started with a real problem &mdash; for me, my family, or my community.</p>

    <div class="projects-grid">
      {projects.map((proj, idx) => (
        <div class="project-card reveal-stagger" style={`transition-delay: ${0.05 * idx}s`}>
          <div class="project-screenshot" style={`background: ${proj.gradient}`}>
            <span class="placeholder-icon-large">{proj.icon}</span>
            <span class="placeholder-name">{proj.name}</span>
          </div>
          <div class="project-body">
            <div class="project-header">
              <div class="project-name">
                <a href={proj.link} target="_blank" rel="noopener">{proj.name}</a>
              </div>
              <span class="status-badge">Active</span>
            </div>
            <div class="project-desc" data-en={proj.desc} data-he={proj.descHe}>{proj.desc}</div>
            <div class="project-tags">
              {proj.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <div class="project-actions">
              <button class="expand-btn" data-en-open="Show less" data-en-closed="Learn more" data-he-open="הצג פחות" data-he-closed="קרא עוד">
                <span>Learn more</span> <span class="arrow">&#x25B8;</span>
              </button>
            </div>
            <div class="project-detail">
              <div class="project-detail-content" data-en={proj.detail} data-he={proj.detailHe}>{proj.detail}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.project-card .expand-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const detail = this.parentElement.nextElementSibling;
        const isOpen = detail.classList.toggle('open');
        this.classList.toggle('open');
        const lang = document.documentElement.lang || 'en';
        this.querySelector('span:first-child').textContent = isOpen
          ? (this.getAttribute(`data-${lang}-open`) || 'Show less')
          : (this.getAttribute(`data-${lang}-closed`) || 'Learn more');
      });
    });
  });
</script>

<style>
  #projects { background: var(--bg-white); transition: background-color 0.3s ease; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-6px);
    border-color: transparent;
  }

  .project-screenshot {
    height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .project-screenshot::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.3) 0%, transparent 50%);
  }

  .placeholder-icon-large {
    font-size: 3rem;
    z-index: 1;
    margin-bottom: 0.5rem;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .placeholder-name {
    font-family: var(--font-heading);
    font-weight: 600; font-size: 1.5rem; color: #fff;
    z-index: 1; text-shadow: 0 2px 15px rgba(0,0,0,0.3); letter-spacing: 0.02em;
  }

  .project-screenshot img {
    width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .project-screenshot img { transform: scale(1.08); }

  .project-body { padding: 1.5rem 1.8rem 1.8rem; flex-grow: 1; display: flex; flex-direction: column; }

  .project-header {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;
  }

  .project-name { font-family: var(--font-heading); font-size: 1.12rem; font-weight: 600; color: var(--text-primary); }
  .project-name a { color: inherit; text-decoration: none; transition: color 0.2s; }
  .project-name a:hover { color: var(--accent); }

  .status-badge {
    font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.7rem; border-radius: 20px;
    background: var(--accent-light); color: var(--accent); text-transform: uppercase; letter-spacing: 0.04em;
  }
  
  :global([data-theme="dark"]) .status-badge { background: rgba(13, 148, 136, 0.2); }

  .project-desc { font-size: 0.92rem; color: var(--text-secondary); margin-bottom: 1rem; line-height: 1.65; flex-grow: 1; }
  .project-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.8rem; }

  .tag {
    font-size: 0.72rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 6px;
    background: var(--accent-light); color: var(--accent); transition: all 0.2s;
  }
  
  :global([data-theme="dark"]) .tag { background: rgba(13, 148, 136, 0.2); color: #5eead4; }

  .tag:hover { background: var(--accent); color: #fff; }

  .project-actions { margin-top: auto; }

  .project-detail { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .project-detail.open { max-height: 300px; }

  .project-detail-content {
    padding-top: 0.8rem; margin-top: 0.5rem; border-top: 1px solid var(--border);
    font-size: 0.9rem; color: var(--text-secondary); line-height: 1.75;
  }

  .expand-btn {
    background: none; border: none; color: var(--accent); font-size: 0.85rem; font-weight: 600;
    cursor: pointer; padding: 0.4rem 0; display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-body); transition: gap 0.3s;
  }
  .expand-btn:hover { gap: 0.7rem; }
  .expand-btn .arrow { display: inline-block; transition: transform 0.3s; font-size: 0.7rem; }
  .expand-btn.open .arrow { transform: rotate(90deg); }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
